# ==========================================================
# ================ SYSTEM CONFIGURATION ====================
# ==========================================================
# For development purposes only. Adjust these values as needed for your environment.
# Host user/group ID, to align permissions on volume-mounted files
# (target/, node_modules/) with your host account.
# Default (1000) is correct for most Linux/WSL2 setups.
# Check with `id -u` / `id -g` if unsure (multi-user systems, macOS, etc.)
# HOST_UID=1000
# HOST_GID=1000


# ==========================================================
# ============= PWNFORGE VERSION CONFIGURATION =============
# ==========================================================
BACKEND_VERSION=1.0.0
FRONTEND_VERSION=1.0.0


# =========================================================
# =============== DATABASE CONFIGURATION ==================
# =========================================================
POSTGRES_USER=pwnforge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pwnforge

# For local development purposes, outside of any containerized environment
# Backend container will use the DATABASE_URL defined in the docker-compose file, which points to the database container.
DATABASE_URL=postgresql://pwnforge:changeme@127.0.0.1:5432/pwnforge

# =========================================================
# =============== REDIS CONFIGURATION =====================
# =========================================================
# For local development purposes, outside of any containerized environment
# Backend container will use the REDIS_URL defined in the docker-compose file, which points to the redis container.
REDIS_URL=redis://127.0.0.1:6379/0


# =========================================================
# ============ JWT AND ENCRYPTION CONFIGURATION ===========
# =========================================================
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here


# =========================================================
# =============== SERVER CONFIGURATION ====================
# =========================================================
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Environment setting for the backend. Change to 'production' in a production environment.
# Used to determine the logging format (JSON for production, pretty for development).
BACKEND_ENV=development

# Logging configuration for the backend. Adjust log levels as needed.
RUST_LOG=info,api=debug,sea_orm=warn,sqlx=warn


# =========================================================
# =============== FRONTEND CONFIGURATION ==================
# =========================================================
HTTP_PORT=80


# =========================================================
# =============== MINIO CONFIGURATION =====================
# =========================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# For local development purposes, outside of any containerized environment
# Backend container will use the S3_ENDPOINT defined in the docker-compose file, which points to the minio container.
MINIO_ENDPOINT=http://127.0.0.1:9000